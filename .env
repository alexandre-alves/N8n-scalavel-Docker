# Configurações de Domínio e Segurança
N8N_HOST=n8n.meudominio.com
WEBHOOK_URL=https://n8n.meudominio.com

N8N_ENCRYPTION_KEY=uma_chave_bem_segura_aqui

# Banco de Dados (Postgres)
POSTGRES_USER=n8n
POSTGRES_PASSWORD=senha_segura_db
POSTGRES_DB=n8n
POSTGRES_HOST=postgres
DB_POSTGRESDB_HOST=IP_DO_SEU_SERVIDOR

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# Configurações de Execução (Queue Mode)
EXECUTIONS_MODE=queue
N8N_QUEUE_BULL_REDIS_HOST=redis
N8N_QUEUE_BULL_REDIS_PORT=6379
REDIS_HOST=IP_DO_SEU_SERVIDOR
